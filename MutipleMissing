import java.util.*;
class Main {
    public static void MutipleMissing(int arr[],int n){
       HashSet<Integer> set = new HashSet<>();
       for(int i=0;i<arr.length;i++){
           set.add(arr[i]);
       }
       for(int i =1 ;i<=n;i++){
           if(!set.contains(i)){
               System.out.print(i +" ");
           }
       }
    }
    public static void main(String[] args) {
        int arr [] = {4,3,2,7,8,2,3,1};
        MutipleMissing(arr,8);
    }
}
