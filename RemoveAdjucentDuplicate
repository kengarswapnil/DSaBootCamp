import java.util.*;
class Main {
    public static String RemoveAdjucentDuplicate(String s){
        Stack<Character> stack = new Stack<>();
        
        for(int i=0;i<s.length();i++){
            char current = s.charAt(i);
            if(!stack.isEmpty() && stack.peek() == current){
                stack.pop();
            }else{
                stack.push(current);
            }
        }
        StringBuilder sb = new StringBuilder();
        for(char i : stack){
            sb.append(i);
        }
        
        return sb.toString();
    }
    public static void main(String[] args) {
        System.out.println(RemoveAdjucentDuplicate("abbaca"));
    }
}
