
class Main {
    public static int missingNumber(int arr[],int n){
        int sum = n * (n + 1)/2;
        int actual  =0;
      for(int i=0;i<arr.length;i++){
          actual += arr[i]; 
       }
       return sum - actual;
    }
    public static void main(String[] args) {
        int arr [] = {1,2,4,5};
        System.out.print(missingNumber(arr,5));
    }
}
