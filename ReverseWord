import java.util.Arrays;
class Main {
    public static void ReverseWord(String s){
        char [] chars = s.toCharArray();
       int i = 0;
       int j = s.length() - 1;
       char temp ;
       while(i < j){
            temp = chars[i];
            chars[i] = chars[j];
            chars[j] = temp;
            i++;
            j--;
       }
       System.out.println(new String( chars));
    }
    public static void main(String[] args) {
        String s = "abcabccccccccc";
        ReverseWord(s);
    }
}
