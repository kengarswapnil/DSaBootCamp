
class Main {
    public static void Pallidrome(String s){
        String rev = "";
        for(int i= s.length()-1;i>= 0 ; i--){
            rev+=s.charAt(i);
        }
        if(s == rev){
            System.out.println("IS Pallindrome");
        }else{
            System.out.println("Is Not Pallindrome");
        }
    }
    public static void main(String[] args) {
        String s = "MOM";
        Pallidrome(s);
    }
}
