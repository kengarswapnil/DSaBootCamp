
class Main {
    public static void reverse (String s){
        String [] rev = s.split(" ");
        for(int i = rev.length - 1;i>=0;i--){
            System.out.print(rev[i]);
            if(i != 0){
                System.out.print(" ");
            }
        }
    }
    public static void main(String[] args) {
        String s = "java fullstack";
        reverse(s);
    }
}
